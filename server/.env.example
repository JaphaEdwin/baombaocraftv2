# Server Configuration
NODE_ENV=development
PORT=3001
API_VERSION=v1

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/baombao_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3000/admin"

# Email (SendGrid / SMTP)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
EMAIL_FROM="noreply@baombao.com"
EMAIL_FROM_NAME="BaoMbao Craft"

# Twilio (SMS)
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="+1234567890"

# MTN Mobile Money API
MTN_MOMO_API_KEY="your-mtn-api-key"
MTN_MOMO_API_USER="your-mtn-api-user"
MTN_MOMO_PRIMARY_KEY="your-mtn-primary-key"
MTN_MOMO_ENVIRONMENT="sandbox"
MTN_MOMO_CALLBACK_URL="https://api.baombao.com/api/v1/webhooks/mtn-momo"

# Airtel Money API
AIRTEL_CLIENT_ID="your-airtel-client-id"
AIRTEL_CLIENT_SECRET="your-airtel-client-secret"
AIRTEL_ENVIRONMENT="sandbox"
AIRTEL_CALLBACK_URL="https://api.baombao.com/api/v1/webhooks/airtel"

# Stripe (Card Payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# WhatsApp Business API
WHATSAPP_TOKEN="your-whatsapp-token"
WHATSAPP_PHONE_ID="your-phone-id"
WHATSAPP_VERIFY_TOKEN="your-verify-token"

# Analytics
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin TOTP Access (Google Authenticator)
# Generate secret: node -e "console.log(require('crypto').randomBytes(20).toString('base64').replace(/[^A-Z2-7]/gi,'').slice(0,32))"
# Or use the /x9k2m/setup endpoint with ADMIN_SETUP_KEY
ADMIN_TOTP_SECRET=""
ADMIN_EMAIL="baombaocraft@gmail.com"
# One-time setup key - REMOVE AFTER INITIAL SETUP
ADMIN_SETUP_KEY="change-this-to-a-random-string-then-remove"
